# Supabase Configuration (Required for Authentication)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI Configuration (Required for AI features)
# Option 1: OpenRouter (recommended - supports many models)
VITE_OPENROUTER_API_KEY=your_openrouter_api_key
VITE_OPENROUTER_MODEL=google/gemma-3-27b-it

# Option 2: GLM (Chinese AI provider)
VITE_GLM_API_KEY=your_glm_api_key
VITE_GLM_MODEL=glm-4.7

# AI Provider selection: 'openrouter' or 'glm'
VITE_AI_PROVIDER=openrouter

# Google Books API (Optional - for books feature)
VITE_GOOGLE_BOOKS_API_KEY=your_google_books_api_key

# TMDB API (Required for Movies and TV Shows)
VITE_TMDB_API_KEY=your_tmdb_api_key
VITE_TMDB_BEARER_TOKEN=your_tmdb_bearer_token
