# Supabase Configuration (Required for Authentication)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI Configuration (Required for AI features)
VITE_GLM_API_KEY=your_glm_api_key
VITE_GLM_MODEL=glm-4.7

# Optional local Vite-only fallback for development.
# Do not use these on production deployments.
VITE_AI_PROVIDER=glm

# Google Books API (Optional - for books feature)
VITE_GOOGLE_BOOKS_API_KEY=your_google_books_api_key
